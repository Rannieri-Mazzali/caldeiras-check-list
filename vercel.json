{
  "version": 2,
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "express",
  "functions": {
    "src/server.ts": {
      "memory": 1024,
      "maxDuration": 60,
      "includeFiles": "public/**"
    }
  },
  "rewrites": [
    {
      "source": "/api/:match*",
      "destination": "/src/server.ts"
    }
  ],
  "routes": [
    {
      "src": "^/api/.*$",
      "dest": "/src/server.ts"
    },
    {
      "src": "^/(?!api).*$",
      "dest": "/public/index.html"
    }
  ],
  "headers": [
    {
      "source": "/public/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600"
        }
      ]
    }
  ]
}
