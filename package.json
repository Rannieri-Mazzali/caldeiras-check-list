{
  "name": "caldeira-checklist",
  "version": "1.0.0",
  "description": "Sistema de Check-list para Caminhões Caldeira Transportadora",
  "main": "dist/server.js",
  "type": "module",
  "scripts": {
    "dev": "node --loader ts-node/esm src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "tailwind": "tailwindcss -i ./src/styles/input.css -o ./public/styles/output.css --watch",
    "vercel-build": "tsc",
    "vercel": "vercel deploy --prod"
  },
  "keywords": [
    "checklist",
    "truck",
    "maintenance"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "axios": "^1.6.2",
    "body-parser": "^1.20.2",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "multer": "^1.4.5-lts.1",
    "twilio": "^5.13.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.10.6",
    "autoprefixer": "^10.4.16",
    "postcss": "^8.4.32",
    "tailwindcss": "^3.4.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3",
    "uuid": "^13.0.0"
  }
}
